{%- comment -%}
  カート下部の「よく一緒に購入されている商品」
  指定コレクション（未指定なら frontpage）から商品を表示。
  カート内の商品は除外する。
{%- endcomment -%}

{%- liquid
  assign reco = section.settings.collection
  if reco == blank
    assign reco = collections['frontpage']
  endif
-%}

{%- if cart != empty and reco != blank and reco.products_count > 0 -%}
  {%- style -%}
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    }

    @media screen and (min-width: 750px) {
      .section-{{ section.id }}-padding {
        padding-top: {{ section.settings.padding_top }}px;
        padding-bottom: {{ section.settings.padding_bottom }}px;
      }
    }
  {%- endstyle -%}

  <div class="cart-reco color-{{ section.settings.color_scheme }} section-{{ section.id }}-padding">
    <div class="page-width">
      <h2 class="cart-reco__title">{{ section.settings.heading | escape }}</h2>

      <ul class="cart-reco__grid" role="list">
        {%- assign shown = 0 -%}
        {%- for product in reco.products -%}
          {%- if shown >= section.settings.products_to_show -%}
            {%- break -%}
          {%- endif -%}

          {%- comment -%} カート内にある商品はスキップ {%- endcomment -%}
          {%- assign in_cart = false -%}
          {%- for line in cart.items -%}
            {%- if line.product_id == product.id -%}
              {%- assign in_cart = true -%}
              {%- break -%}
            {%- endif -%}
          {%- endfor -%}

          {%- unless in_cart -%}
            {%- assign shown = shown | plus: 1 -%}
            <li class="cart-reco__item">
              <a href="{{ product.url }}" class="cart-reco__card">
                <div class="cart-reco__media">
                  {%- if product.featured_image -%}
                    <img
                      src="{{ product.featured_image | image_url: width: 500 }}"
                      srcset="
                        {{ product.featured_image | image_url: width: 300 }} 300w,
                        {{ product.featured_image | image_url: width: 500 }} 500w,
                        {{ product.featured_image | image_url: width: 800 }} 800w
                      "
                      sizes="(min-width: 990px) 22vw, 45vw"
                      alt="{{ product.featured_image.alt | escape }}"
                      width="{{ product.featured_image.width }}"
                      height="{{ product.featured_image.height }}"
                      loading="lazy"
                    >
                  {%- endif -%}
                </div>
                <div class="cart-reco__name">{{ product.title | escape }}</div>
                <div class="cart-reco__price">{{ product.price | money }}</div>
              </a>
            </li>
          {%- endunless -%}
        {%- endfor -%}
      </ul>
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "カートおすすめ商品",
  "class": "cart-recommendations-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "見出し",
      "default": "よく一緒に購入されている商品"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "表示するコレクション",
      "info": "未選択の場合は「注目のアイテム（frontpage）」を表示します"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 8,
      "step": 1,
      "label": "表示する商品数",
      "default": 4
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "カラースキーム",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "余白"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "上の余白",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "下の余白",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "カートおすすめ商品"
    }
  ]
}
{% endschema %}
