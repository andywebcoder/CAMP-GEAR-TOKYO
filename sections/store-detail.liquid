{%- comment -%}
  店舗詳細セクション（STORE-detail）
  パンくず / ヒーロー / 店舗情報＋店舗の特徴 / アクセス（地図＋交通手段別）
{%- endcomment -%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  #StoreHero-{{ section.id }} {
    {%- if section.settings.hero_image != blank -%}
      background-image: linear-gradient(90deg, rgba(20,22,28,0.92), rgba(20,22,28,0.55)), url({{ section.settings.hero_image | image_url: width: 2000 }});
    {%- else -%}
      background: linear-gradient(90deg, #23262e, #3a3f4a);
    {%- endif -%}
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">

  {%- comment -%} パンくず {%- endcomment -%}
  <nav class="store-detail__crumbs page-width" aria-label="パンくず">
    <a href="{{ routes.root_url }}">ホーム</a>
    <span aria-hidden="true">/</span>
    {%- if section.settings.list_url != blank -%}
      <a href="{{ section.settings.list_url }}">店舗一覧</a>
      <span aria-hidden="true">/</span>
    {%- endif -%}
    <span class="store-detail__crumbs-current">{{ section.settings.store_name | escape }}</span>
  </nav>

  {%- comment -%} ヒーロー {%- endcomment -%}
  <div class="store-detail__hero" id="StoreHero-{{ section.id }}">
    <div class="page-width">
      <h1 class="store-detail__hero-title">{{ section.settings.store_name | escape }}</h1>
      {%- if section.settings.tagline != blank -%}
        <p class="store-detail__hero-tagline">{{ section.settings.tagline | escape }}</p>
      {%- endif -%}
    </div>
  </div>

  <div class="page-width store-detail__inner">

    {%- comment -%} 店舗情報 ＋ 店舗の特徴 {%- endcomment -%}
    <div class="store-detail__cols">

      {%- comment -%} 左：店舗情報カード {%- endcomment -%}
      <div class="store-info">
        <h2 class="store-detail__subtitle">店舗情報</h2>

        <div class="store-info__item">
          <p class="store-info__label">所在地</p>
          <p class="store-info__value">
            {%- if section.settings.postal != blank -%}〒{{ section.settings.postal | escape }}<br>{%- endif -%}
            {{ section.settings.address | escape }}
            {%- if section.settings.building != blank -%}<br>{{ section.settings.building | escape }}{%- endif -%}
          </p>
        </div>

        {%- if section.settings.tel != blank or section.settings.fax != blank -%}
          <div class="store-info__item">
            <p class="store-info__label">電話番号</p>
            <p class="store-info__value">
              {%- if section.settings.tel != blank -%}TEL: <a href="tel:{{ section.settings.tel | remove: '-' }}">{{ section.settings.tel | escape }}</a>{%- endif -%}
              {%- if section.settings.fax != blank -%}<br>FAX: {{ section.settings.fax | escape }}{%- endif -%}
            </p>
          </div>
        {%- endif -%}

        <div class="store-info__item">
          <p class="store-info__label">営業時間</p>
          <table class="store-info__hours">
            {%- if section.settings.hours_weekday != blank -%}<tr><th>平日</th><td>{{ section.settings.hours_weekday | escape }}</td></tr>{%- endif -%}
            {%- if section.settings.hours_weekend != blank -%}<tr><th>土日</th><td>{{ section.settings.hours_weekend | escape }}</td></tr>{%- endif -%}
            {%- if section.settings.hours_holiday != blank -%}<tr><th>日祝・特別</th><td>{{ section.settings.hours_holiday | escape }}</td></tr>{%- endif -%}
            {%- if section.settings.closed != blank -%}<tr><th>定休日</th><td>{{ section.settings.closed | escape }}</td></tr>{%- endif -%}
          </table>
        </div>

        {%- if section.settings.categories != blank -%}
          <div class="store-info__item">
            <p class="store-info__label">取扱カテゴリー</p>
            <div class="store-info__tags">
              {%- assign cats = section.settings.categories | split: ',' -%}
              {%- for cat in cats -%}
                {%- assign c = cat | strip -%}
                {%- if c != blank -%}<span class="store-info__tag">{{ c | escape }}</span>{%- endif -%}
              {%- endfor -%}
            </div>
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} 右：店舗の特徴 {%- endcomment -%}
      {%- assign feature_blocks = section.blocks | where: 'type', 'feature' -%}
      {%- if feature_blocks.size > 0 -%}
        <div class="store-features">
          <h2 class="store-detail__subtitle">店舗の特徴</h2>
          <div class="store-features__grid">
            {%- for block in feature_blocks -%}
              <div class="feature-card" {{ block.shopify_attributes }}>
                {%- if block.settings.icon != blank -%}<span class="feature-card__icon" aria-hidden="true">{{ block.settings.icon }}</span>{%- endif -%}
                <p class="feature-card__title">{{ block.settings.title | escape }}</p>
                {%- if block.settings.description != blank -%}<p class="feature-card__desc">{{ block.settings.description | escape }}</p>{%- endif -%}
              </div>
            {%- endfor -%}
          </div>
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} アクセス {%- endcomment -%}
    <div class="store-detail__access">
      <h2 class="store-detail__subtitle">アクセス</h2>
      <div class="store-detail__map">
        {%- if section.settings.map_embed != blank -%}
          {{ section.settings.map_embed }}
        {%- else -%}
          <div class="store-detail__map-placeholder">Google Maps（管理画面で埋め込みコードを設定）</div>
        {%- endif -%}
      </div>

      {%- if section.settings.access_train != blank or section.settings.access_car != blank or section.settings.access_bus != blank -%}
        <div class="store-detail__access-tips">
          {%- if section.settings.access_train != blank -%}
            <div class="access-tip">
              <p class="access-tip__title"><span aria-hidden="true">🚃</span>電車でお越しの方</p>
              <p class="access-tip__text">{{ section.settings.access_train | escape | newline_to_br }}</p>
            </div>
          {%- endif -%}
          {%- if section.settings.access_car != blank -%}
            <div class="access-tip">
              <p class="access-tip__title"><span aria-hidden="true">🚗</span>車でお越しの方</p>
              <p class="access-tip__text">{{ section.settings.access_car | escape | newline_to_br }}</p>
            </div>
          {%- endif -%}
          {%- if section.settings.access_bus != blank -%}
            <div class="access-tip">
              <p class="access-tip__title"><span aria-hidden="true">🚌</span>バスでお越しの方</p>
              <p class="access-tip__text">{{ section.settings.access_bus | escape | newline_to_br }}</p>
            </div>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>

  </div>
</div>

{%- stylesheet -%}
  .store-detail__crumbs {
    padding-top: 1.6rem;
    padding-bottom: 1.6rem;
    font-size: 1.2rem;
    color: rgba(var(--color-foreground), 0.55);
  }
  .store-detail__crumbs a { color: inherit; text-decoration: none; }
  .store-detail__crumbs a:hover { text-decoration: underline; }
  .store-detail__crumbs span { margin: 0 0.6rem; }
  .store-detail__crumbs-current { color: rgba(var(--color-foreground), 0.85); }

  .store-detail__hero {
    background-size: cover;
    background-position: center;
    color: #fff;
    padding: 5rem 0;
    margin-bottom: 4rem;
  }
  .store-detail__hero-title { margin: 0; color: #fff; }
  .store-detail__hero-tagline { margin: 1rem 0 0; opacity: 0.9; font-size: 1.4rem; }

  .store-detail__subtitle {
    font-size: 1.7rem;
    margin: 0 0 1.6rem;
  }

  .store-detail__cols {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    margin-bottom: 5rem;
  }
  @media screen and (min-width: 750px) {
    .store-detail__cols { grid-template-columns: 1.1fr 0.9fr; }
  }

  .store-info {
    background: rgba(var(--color-foreground), 0.04);
    padding: 2.4rem;
  }
  .store-info__item {
    padding: 1.4rem 0;
    border-bottom: 1px solid rgba(var(--color-foreground), 0.1);
  }
  .store-info__item:first-of-type { padding-top: 0; }
  .store-info__item:last-child { border-bottom: none; padding-bottom: 0; }
  .store-info__label {
    margin: 0 0 0.6rem;
    font-weight: 700;
    font-size: 1.35rem;
    color: #f97316;
  }
  .store-info__value { margin: 0; font-size: 1.4rem; line-height: 1.7; }
  .store-info__value a { color: inherit; }

  .store-info__hours { width: 100%; border-collapse: collapse; font-size: 1.35rem; }
  .store-info__hours th {
    text-align: left;
    font-weight: 400;
    color: rgba(var(--color-foreground), 0.6);
    padding: 0.4rem 1.5rem 0.4rem 0;
    white-space: nowrap;
    vertical-align: top;
    width: 6em;
  }
  .store-info__hours td { padding: 0.4rem 0; }

  .store-info__tags { display: flex; flex-wrap: wrap; gap: 0.6rem; }
  .store-info__tag {
    font-size: 1.15rem;
    padding: 0.4rem 1rem;
    background: rgb(var(--color-foreground));
    color: rgb(var(--color-background));
  }

  .store-features__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.4rem;
  }
  .feature-card {
    border: 1px solid rgba(var(--color-foreground), 0.12);
    padding: 1.8rem 1.4rem;
  }
  .feature-card__icon { font-size: 2rem; display: block; margin-bottom: 0.8rem; }
  .feature-card__title { margin: 0 0 0.6rem; font-weight: 700; font-size: 1.4rem; }
  .feature-card__desc { margin: 0; font-size: 1.25rem; line-height: 1.7; color: rgba(var(--color-foreground), 0.7); }

  .store-detail__map { aspect-ratio: 21 / 9; background: rgba(var(--color-foreground), 0.06); overflow: hidden; }
  .store-detail__map :is(iframe, img) { width: 100%; height: 100%; border: 0; display: block; }
  .store-detail__map-placeholder {
    display: flex; align-items: center; justify-content: center; height: 100%;
    color: rgba(var(--color-foreground), 0.5); font-size: 1.3rem;
  }

  .store-detail__access-tips {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.6rem;
    margin-top: 2.4rem;
  }
  @media screen and (min-width: 750px) {
    .store-detail__access-tips { grid-template-columns: repeat(3, 1fr); }
  }
  .access-tip {
    border-top: 3px solid #f97316;
    background: rgba(var(--color-foreground), 0.03);
    padding: 1.6rem;
  }
  .access-tip__title {
    margin: 0 0 0.8rem;
    font-weight: 700;
    font-size: 1.4rem;
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .access-tip__text { margin: 0; font-size: 1.3rem; line-height: 1.8; color: rgba(var(--color-foreground), 0.75); }
{%- endstylesheet -%}

{% schema %}
{
  "name": "店舗詳細",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "url", "id": "list_url", "label": "店舗一覧ページのURL（パンくず用）" },
    { "type": "text", "id": "store_name", "label": "店舗名", "default": "CAMP GEAR TOKYO 渋谷店" },
    { "type": "text", "id": "tagline", "label": "キャッチコピー", "default": "都心最大級の品揃えと専門スタッフがあなたの冒険をサポート" },
    { "type": "image_picker", "id": "hero_image", "label": "ヒーロー背景画像" },
    { "type": "header", "content": "店舗情報" },
    { "type": "text", "id": "postal", "label": "郵便番号", "default": "150-0041" },
    { "type": "text", "id": "address", "label": "住所", "default": "東京都渋谷区神南1-12-16" },
    { "type": "text", "id": "building", "label": "建物名・階", "default": "アップルビル 1F" },
    { "type": "text", "id": "tel", "label": "電話番号", "default": "03-1234-5678" },
    { "type": "text", "id": "fax", "label": "FAX番号", "default": "03-1234-5679" },
    { "type": "text", "id": "hours_weekday", "label": "平日の営業時間", "default": "11:00 - 20:00" },
    { "type": "text", "id": "hours_weekend", "label": "土日の営業時間", "default": "10:00 - 19:00" },
    { "type": "text", "id": "hours_holiday", "label": "日祝・特別の営業時間", "default": "10:00 - 19:00" },
    { "type": "text", "id": "closed", "label": "定休日", "default": "年中無休（年末年始を除く）" },
    { "type": "text", "id": "categories", "label": "取扱カテゴリー（カンマ区切り）", "default": "テント・タープ,寝袋・マット,調理器具,ランタン/照明,バックパック,ライト・シューズ" },
    { "type": "header", "content": "アクセス" },
    { "type": "html", "id": "map_embed", "label": "Google Mapsの埋め込みコード（iframe）" },
    { "type": "textarea", "id": "access_train", "label": "電車でお越しの方", "default": "JR渋谷駅ハチ公口より徒歩5分\n東京メトロ各線 渋谷駅 B1出口より徒歩3分" },
    { "type": "textarea", "id": "access_car", "label": "車でお越しの方", "default": "首都高速3号渋谷線 渋谷出口より約5分\n提携駐車場あり（2,000円以上で1時間無料）" },
    { "type": "textarea", "id": "access_bus", "label": "バスでお越しの方", "default": "都営バス「渋谷神南」バス停より徒歩1分\n各方面から渋谷駅行き多数運行" },
    { "type": "header", "content": "余白" },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "下の余白", "default": 60 },
    { "type": "color_scheme", "id": "color_scheme", "label": "カラースキーム", "default": "scheme-1" }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "店舗の特徴",
      "settings": [
        { "type": "text", "id": "icon", "label": "アイコン（絵文字）", "default": "⛺" },
        { "type": "text", "id": "title", "label": "タイトル", "default": "テント各種" },
        { "type": "textarea", "id": "description", "label": "説明", "default": "有名ブランドのテントを常時50張り以上展示。実物を見て選べます。" }
      ]
    }
  ],
  "presets": [
    {
      "name": "店舗詳細",
      "blocks": [
        { "type": "feature", "settings": { "icon": "⛺", "title": "テント各種", "description": "有名ブランドのテントを常時50張り以上展示。実物を見て選べます。" } },
        { "type": "feature", "settings": { "icon": "🪑", "title": "椅子・テーブル類", "description": "アウトドアチェア・テーブルを豊富に取り揃え。座り心地を試せます。" } },
        { "type": "feature", "settings": { "icon": "🛌", "title": "寝袋・マット類", "description": "オールシーズン対応の寝袋・マットを展示。快眠グッズもご相談ください。" } },
        { "type": "feature", "settings": { "icon": "☕", "title": "カフェスペース", "description": "アウトドア用品に囲まれたカフェで、コーヒーを飲みながら相談できます。" } }
      ]
    }
  ]
}
{% endschema %}
