{%- if data == blank -%}
  <p class="product-reviews__empty">この商品のレビューはまだありません。</p>
{%- else -%}
  {%- assign reviews = data | split: '~~' -%}
  {%- assign total = 0 -%}
  {%- for r in reviews -%}
    {%- assign f = r | split: '|' -%}
    {%- assign total = total | plus: f[0] -%}
  {%- endfor -%}
  {%- assign count = reviews.size -%}
  {%- assign avg = total | times: 1.0 | divided_by: count | round: 1 -%}
  {%- assign avg_star = avg | round -%}

  <div class="product-reviews">
    <div class="product-reviews__summary">
      <div class="product-reviews__score">{{ avg }}</div>
      <div>
        <div class="product-reviews__stars" aria-hidden="true">
          {%- for i in (1..5) -%}
            {%- if i <= avg_star -%}★{%- else -%}☆{%- endif -%}
          {%- endfor -%}
        </div>
        <div class="product-reviews__count">{{ count }}件のレビュー</div>
      </div>
    </div>

    <ul class="product-reviews__list">
      {%- for r in reviews -%}
        {%- assign f = r | split: '|' -%}
        <li class="product-reviews__item">
          <div class="product-reviews__item-head">
            <span class="product-reviews__stars product-reviews__stars--sm" aria-hidden="true">
              {%- for i in (1..5) -%}
                {%- assign rt = f[0] | plus: 0 -%}
                {%- if i <= rt -%}★{%- else -%}☆{%- endif -%}
              {%- endfor -%}
            </span>
            <span class="product-reviews__name">{{ f[4] | escape }}</span>
            <span class="product-reviews__date">{{ f[3] | date: '%Y年%-m月%-d日' }}</span>
          </div>
          <p class="product-reviews__title">{{ f[1] | escape }}</p>
          <p class="product-reviews__body">{{ f[2] | escape }}</p>
        </li>
      {%- endfor -%}
    </ul>
  </div>
{%- endif -%}
